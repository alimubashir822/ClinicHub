datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Organization {
  id          String     @id @default(uuid())
  name        String
  logoUrl     String?
  primaryColor String    @default("#0f766e")
  secondaryColor String  @default("#111827")
  fontFamily   String    @default("Inter")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  locations   Location[]
  regions     Region[]
}

model Region {
  id             String       @id @default(uuid())
  name           String       // e.g. Northeast, South, Midwest, West
  managerName    String?      // Regional manager name
  managerEmail   String?      // Regional manager contact email
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locations      Location[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Location {
  id           String        @id @default(uuid())
  name         String
  slug         String        @unique
  address      String
  city         String
  state        String
  zip          String
  phone        String
  email        String
  hours        String
  templateType String        // DENTAL, MEDICAL, URGENT_CARE, SPA
  status       String        @default("ACTIVE") // ACTIVE, DRAFT
  growthScore  Int           @default(80)
  
  // Health Score Sub-metrics (AI Franchise Health Score™)
  seoScore     Int           @default(85)
  bookingScore Int           @default(80)
  reviewScore  Int           @default(88)
  contentScore Int           @default(85)
  patientScore Int           @default(80)

  regionId     String?
  region       Region?       @relation(fields: [regionId], references: [id], onDelete: SetNull)

  organizationId String
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  
  pages        Page[]
  providers    Provider[]
  services     LocationService[]
  appointments Appointment[]
  reviews      Review[]
  analytics    Analytics[]
}

model Page {
  id          String   @id @default(uuid())
  slug        String
  title       String
  content     String
  type        String
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([locationId, slug])
}

model Service {
  id          String            @id @default(uuid())
  name        String
  description String
  duration    Int
  price       Float
  category    String
  isGlobal    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  locations   LocationService[]
  appointments Appointment[]
}

model LocationService {
  locationId String
  serviceId  String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([locationId, serviceId])
}

model Provider {
  id          String        @id @default(uuid())
  name        String
  title       String
  bio         String
  specialty   String
  imageUrl    String?
  email       String
  profileViews Int          @default(0) // View counter for reputation engine
  
  locationId  String
  location    Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  appointments Appointment[]
}

model Lead {
  id          String   @id @default(uuid())
  name        String
  email       String
  phone       String
  status      String
  source      String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Appointment {
  id           String   @id @default(uuid())
  patientName  String
  patientEmail String
  patientPhone String
  appointmentDate String
  appointmentTime String
  status       String
  notes        String?
  
  serviceId    String
  service      Service  @relation(fields: [serviceId], references: [id])
  providerId   String
  provider     Provider @relation(fields: [providerId], references: [id])
  locationId   String
  location     Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Review {
  id           String   @id @default(uuid())
  patientName  String
  rating       Int
  content      String
  date         String
  replyContent String?
  replyStatus  String   @default("NONE")
  locationId   String
  location     Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Analytics {
  id           String   @id @default(uuid())
  date         String
  visitors     Int
  leads        Int
  bookings     Int
  locationId   String
  location     Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, date])
}
